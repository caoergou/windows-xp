{
  "name": "@caoergou/windows-xp",
  "version": "0.1.0",
  "description": "A faithful recreation of Windows XP desktop in React - Relive the millennium era with authentic Y2K aesthetics",
  "main": "dist/windows-xp.umd.js",
  "module": "dist/windows-xp.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/windows-xp.es.js",
      "require": "./dist/windows-xp.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "rm -rf dist && vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"e2e/**/*.{ts,tsx,css,json}\" \"test/**/*.{ts,tsx,css,json}\" \"*.{ts,tsx,cjs,mjs,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"e2e/**/*.{ts,tsx,css,json}\" \"test/**/*.{ts,tsx,css,json}\" \"*.{ts,tsx,cjs,mjs,js,json}\""
  },
  "keywords": [
    "windows-xp",
    "react",
    "nostalgia",
    "retro",
    "y2k",
    "millennium",
    "desktop-simulator",
    "ui-recreation",
    "xp-theme",
    "vintage",
    "component"
  ],
  "author": "caoergou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caoergou/windows-xp.git"
  },
  "homepage": "http://eric.run.place/windows-xp/",
  "bugs": {
    "url": "https://github.com/caoergou/windows-xp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "framer-motion": "^10.0.0",
    "i18next": "^25.0.0",
    "immer": "^10.0.0 || ^11.0.0",
    "lucide-react": "^0.400.0",
    "react-draggable": "^4.4.0",
    "react-i18next": "^16.0.0",
    "react-old-icons": "^1.0.0",
    "react-resizable": "^3.0.0",
    "styled-components": "^5.0.0 || ^6.0.0",
    "xp.css": "^0.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "framer-motion": "^10.16.4",
    "i18next": "^25.8.13",
    "immer": "^11.1.11",
    "lucide-react": "^0.556.0",
    "react-draggable": "^4.4.6",
    "react-i18next": "^16.5.4",
    "react-old-icons": "^1.0.2",
    "react-resizable": "^3.0.5",
    "styled-components": "^6.1.1",
    "vite-plugin-dts": "^4.5.3",
    "xp.css": "^0.2.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy": "^1.0.2",
    "jsdom": "^27.3.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
